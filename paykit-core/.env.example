# Server
NODE_ENV=development
PORT=3000

# Stellar Testnet
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org

# USDC on Stellar Testnet (Circle testnet issuer)
STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# MongoDB
MONGODB_URI=fwfff
# Redis
REDIS_URL=redis://localhost:6379


WALLET_ENCRYPTION_KEY=your_64_char_hex_key_here

# Idempotency key TTL (seconds)
IDEMPOTENCY_TTL=86400

# Optional: PYUSD (for treasury and payments)
# STELLAR_PYUSD_ISSUER=

# Optional: Webhook retry tuning
# WEBHOOK_MAX_RETRIES=3
# WEBHOOK_RETRY_DELAY_MS=5000

# Onramp / Offramp (MoonPay, Ramp)
# MOONPAY_API_KEY=pk_test_...
# RAMP_API_KEY=...

# RPC / Node: use private Horizon when set
# HORIZON_PRIVATE_URL=https://...

# Indexer (default: enabled). Set INDEXER_ENABLED=false to disable.
# INDEXER_ENABLED=true

# Developer platform: OAuth and session
FRONTEND_URL=http://localhost:3000
PAYKIT_API_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
