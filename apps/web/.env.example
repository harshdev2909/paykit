# PayKit HTTP API (Express). Must differ from the Next.js dev port if both run locally.
# Example: Next on :3000 → API on :3001 (export PORT=3001 in apps/api/.env)
NEXT_PUBLIC_PAYKIT_API_URL=http://localhost:3001
# Production (committed in .env.production): https://paykit-1.onrender.com — mirror on Vercel env.

# Optional: authorize Vercel Cron `/api/cron/keep-alive` with `Authorization: Bearer …`
# CRON_SECRET=

# Optional: "Edit on GitHub" links in docs footer (path to `app/(site)/docs` in your repo, no trailing slash).
# NEXT_PUBLIC_DOCS_GITHUB_EDIT_BASE=https://github.com/your-org/paykit/blob/main/apps/web/app/(site)/docs

# Demo (/demo): server-side merchant API key + optional internal API URL for Next route handlers.
# PAYKIT_INTERNAL_API_URL=http://127.0.0.1:3001
PAYKIT_DEMO_MERCHANT_API_KEY=pk_test_your_demo_merchant_key

# Cloudflare Turnstile (first prompt only). Omit TURNSTILE_SECRET_KEY to skip verification in development.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
