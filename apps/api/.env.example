# Server
NODE_ENV=development
# If Next.js uses 3000, set PORT=3001 here so Playground can use NEXT_PUBLIC_PAYKIT_API_URL=http://localhost:3001
PORT=3001

# Stellar Testnet
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org

# USDC on Stellar Testnet (Circle testnet issuer)
STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Soroban — PayKit spending-policy WASM contract (C-address from `pnpm run deploy` in contracts/spending-policy)
# Exposes contract id in GET /v1/x402/supported under `soroban`. Classic custodial agent wallets are separate until smart accounts wire up.
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# SPENDING_POLICY_CONTRACT_ID=

# MongoDB (current app data; Phase 3 may move receipts to Postgres)
MONGODB_URI=mongodb://localhost:27017/paykit

# Postgres (Prisma; receipts + webhook delivery metadata for /v1)
DATABASE_URL=postgresql://localhost:5432/paykit

# OpenTelemetry (optional). Enable tracing by setting an OTLP endpoint and/or console exporter.
# OTEL_SDK_DISABLED=true
# OTEL_SERVICE_NAME=paykit-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_TRACES_EXPORTER=console
# Redis (optional). If unset or empty, the API runs without Redis: no rate limiting, no idempotency cache, no event stream.
# Set for production to enable rate limits, idempotency, webhook queue, and event streaming (e.g. Render Redis, Upstash).
# REDIS_URL=redis://localhost:6379


WALLET_ENCRYPTION_KEY=your_64_char_hex_key_here

# Idempotency key TTL (seconds)
IDEMPOTENCY_TTL=86400

# Optional: PYUSD (for treasury and payments)
# STELLAR_PYUSD_ISSUER=

# Optional: Webhook retry tuning
# WEBHOOK_MAX_RETRIES=3
# WEBHOOK_RETRY_DELAY_MS=5000

# Developer platform: OAuth and session
FRONTEND_URL=http://localhost:3001
PAYKIT_API_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS: allowed origins (comma-separated). Defaults to FRONTEND_URL if not set.
# Example production: CORS_ORIGINS=https://paykit.vercel.app,https://www.paykit.vercel.app
# CORS_ORIGINS=
